# Copy this file to .env and replace the placeholder values.
#
# .env is ignored by git and is loaded automatically when you run the CLI from
# this project directory. Shell environment variables and command-line flags
# override these values.

IMAP_CLEANUP_HOST=imap.example.com
IMAP_CLEANUP_PORT=993
IMAP_CLEANUP_USERNAME=user@example.com
IMAP_CLEANUP_PASSWORD=replace-with-an-app-password
