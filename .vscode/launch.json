{
  "version": "0.2.0",

  "configurations": [
    {
      "name": "imap-cleanup: folders",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": ["folders"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: folders json",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": ["folders", "--format", "json"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete dry run",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": ["delete", "--mailbox", "Archive", "--before", "2025-01-01"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete dry run json",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": [
        "delete",
        "--mailbox",
        "Archive",
        "--before",
        "2025-01-01",
        "--format",
        "json"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete folder dry run",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": ["delete-folder", "--mailbox", "Old Projects"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete folder dry run json",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": [
        "delete-folder",
        "--mailbox",
        "Old Projects",
        "--format",
        "json"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete folder recursive dry run",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": ["delete-folder", "--mailbox", "Old Projects", "--recursive"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    },
    {
      "name": "imap-cleanup: delete folder recursive dry run json",
      "type": "debugpy",
      "request": "launch",
      "module": "imap_cleanup",
      "args": [
        "delete-folder",
        "--mailbox",
        "Old Projects",
        "--recursive",
        "--format",
        "json"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "preLaunchTask": "uv: sync"
    }
  ]
}
