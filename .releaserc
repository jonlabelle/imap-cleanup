{
  "branches": [
    "main"
  ],
  "repositoryUrl": "https://github.com/jonlabelle/imap-cleanup.git",
  "tagFormat": "v${version}",
  "debug": false,
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Changelog"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "python3 scripts/set_project_version.py ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "CHANGELOG.md",
          "pyproject.toml",
          "uv.lock"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "releaseNameTemplate": "Release <%= nextRelease.gitTag %>",
        "assets": [
          {
            "path": "release-binaries/**/imap-cleanup-linux-x86_64",
            "label": "imap-cleanup Linux x86_64"
          },
          {
            "path": "release-binaries/**/imap-cleanup-macos-arm64",
            "label": "imap-cleanup macOS arm64"
          },
          {
            "path": "release-binaries/**/imap-cleanup-windows-x86_64.exe",
            "label": "imap-cleanup Windows x86_64"
          },
          {
            "path": "release-binaries/SHA256SUMS.txt",
            "label": "SHA-256 checksums"
          }
        ]
      }
    ]
  ]
}
